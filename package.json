{
  "name": "@ogis/navigator",
  "version": "1.0.11",
  "type": "module",
  "description": "A Vue 3-based map navigator powered by MapLibre GL JS",
  "homepage": "https://www.ogis.org/navigator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenGIS/Navigator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/navigator.js",
  "module": "./dist/navigator.js",
  "style": "./dist/navigator.css",
  "exports": {
    ".": {
      "import": "./dist/navigator.js"
    },
    "./navigator.css": "./dist/navigator.css",
    "./dist/navigator.css": "./dist/navigator.css",
    "./static/*": "./dist/static/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js",
    "test": "playwright test",
    "check:sync": "node scripts/check-sync.js",
    "prepublishOnly": "npm run build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "maplibre-gl": "^5.0.0",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "@ogis/icons": "^0.2.4",
    "bootstrap": "^5.3.8",
    "magvar": "^2.0.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "maplibre-gl": "^5.0.0",
    "vite": "^8.0.0"
  }
}
